# Server configuration
PORT=3001

# Supabase PostgreSQL Connection
# Replace [YOUR-PASSWORD] with your actual Supabase DB password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Auth0 JWT Validation Settings
# The API Identifier (Audience) configured in Auth0
AUTH0_AUDIENCE=https://agritrust-ai/api
# The URL of your Auth0 tenant (e.g. https://agritrust-ai.us.auth0.com/) - MUST end with a trailing slash
AUTH0_ISSUER_URL=https://your-tenant-name.auth0.com/

# Grok API (Custom AI Model)
GROK_API_KEY=your_grok_api_key_here

# IPFS Settings
IPFS_PROJECT_ID=your_ipfs_project_id_here
IPFS_PROJECT_SECRET=your_ipfs_project_secret_here
