// This is the Prisma schema for AgriTrust AI
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  FARMER
  BUYER
  TRANSPORTER
  REGULATOR
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  AT_WAREHOUSE
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ProductStatus {
  REGISTERED
  VERIFIED
  IN_TRANSIT
  DELIVERED
  SOLD
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  auth0Id       String   @unique @map("auth0_id")
  email         String   @unique
  name          String
  role          Role     @default(FARMER)
  phone         String?
  avatar        String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  farms         Farm[]
  shipmentsSent Shipment[]     @relation("ShipmentSender")
  shipmentsTransported Shipment[] @relation("ShipmentTransporter")
  purchases     Payment[]      @relation("PaymentBuyer")
  sales         Payment[]      @relation("PaymentSeller")
  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────────
// FARMS
// ─────────────────────────────────────────────

model Farm {
  id            String   @id @default(uuid())
  name          String
  location      String
  latitude      Float?
  longitude     Float?
  size          Float?
  sizeUnit      String?  @map("size_unit")
  description   String?
  ownerId       String   @map("owner_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  harvests      Harvest[]

  @@map("farms")
}

// ─────────────────────────────────────────────
// HARVESTS
// ─────────────────────────────────────────────

model Harvest {
  id            String   @id @default(uuid())
  farmId        String   @map("farm_id")
  cropType      String   @map("crop_type")
  quantity      Float
  quantityUnit  String   @map("quantity_unit")
  harvestDate   DateTime @map("harvest_date")
  qualityGrade  String?  @map("quality_grade")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  farm          Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  products      Product[]

  @@map("harvests")
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

model Product {
  id            String        @id @default(uuid())
  name          String
  description   String?
  category      String
  batchNumber   String        @unique @map("batch_number")
  quantity      Float
  quantityUnit  String        @map("quantity_unit")
  price         Float?
  currency      String        @default("NGN")
  status        ProductStatus @default(REGISTERED)
  harvestId     String        @map("harvest_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  harvest       Harvest       @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  digitalTwin   DigitalTwin?
  qrCode        QrCode?
  certificates  Certificate[]
  shipments     Shipment[]
  payments      Payment[]

  @@map("products")
}

// ─────────────────────────────────────────────
// DIGITAL TWINS (Blockchain-anchored)
// ─────────────────────────────────────────────

model DigitalTwin {
  id              String   @id @default(uuid())
  productId       String   @unique @map("product_id")
  blockchainTxHash String? @map("blockchain_tx_hash")
  contractAddress String?  @map("contract_address")
  tokenId         String?  @map("token_id")
  metadataUri     String?  @map("metadata_uri")
  ownerAddress    String?  @map("owner_address")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("digital_twins")
}

// ─────────────────────────────────────────────
// QR CODES
// ─────────────────────────────────────────────

model QrCode {
  id            String   @id @default(uuid())
  productId     String   @unique @map("product_id")
  code          String   @unique
  imageUrl      String?  @map("image_url")
  scanCount     Int      @default(0) @map("scan_count")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("qr_codes")
}

// ─────────────────────────────────────────────
// SHIPMENTS
// ─────────────────────────────────────────────

model Shipment {
  id              String         @id @default(uuid())
  productId       String         @map("product_id")
  senderId        String         @map("sender_id")
  transporterId   String?        @map("transporter_id")
  origin          String
  destination     String
  status          ShipmentStatus @default(PENDING)
  currentLocation String?        @map("current_location")
  latitude        Float?
  longitude       Float?
  estimatedArrival DateTime?     @map("estimated_arrival")
  actualArrival    DateTime?     @map("actual_arrival")
  blockchainTxHash String?       @map("blockchain_tx_hash")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  sender          User           @relation("ShipmentSender", fields: [senderId], references: [id])
  transporter     User?          @relation("ShipmentTransporter", fields: [transporterId], references: [id])

  @@map("shipments")
}

// ─────────────────────────────────────────────
// WALLETS & PAYMENTS
// ─────────────────────────────────────────────

model Wallet {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  walletAddress   String?  @unique @map("wallet_address")
  balance         Float    @default(0)
  currency        String   @default("NGN")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("wallets")
}

model Payment {
  id              String        @id @default(uuid())
  productId       String        @map("product_id")
  buyerId         String        @map("buyer_id")
  sellerId        String        @map("seller_id")
  amount          Float
  currency        String        @default("NGN")
  status          PaymentStatus @default(PENDING)
  blockchainTxHash String?      @map("blockchain_tx_hash")
  receiptUrl      String?       @map("receipt_url")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  product         Product       @relation(fields: [productId], references: [id])
  buyer           User          @relation("PaymentBuyer", fields: [buyerId], references: [id])
  seller          User          @relation("PaymentSeller", fields: [sellerId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// CERTIFICATES
// ─────────────────────────────────────────────

model Certificate {
  id              String   @id @default(uuid())
  productId       String   @map("product_id")
  name            String
  issuedBy        String   @map("issued_by")
  issuedAt        DateTime @map("issued_at")
  expiresAt       DateTime? @map("expires_at")
  documentUrl     String?  @map("document_url")
  blockchainTxHash String? @map("blockchain_tx_hash")
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  title         String
  message       String
  type          String
  isRead        Boolean  @default(false) @map("is_read")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  action        String
  entity        String
  entityId      String   @map("entity_id")
  details       Json?
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
